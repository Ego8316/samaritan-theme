		"tab.activeBackground": "#8d8d8d",
		"tab.activeForeground": "#000000",
		"tab.inactiveBackground": "#d9dada",
		"tab.inactiveForeground": "#000000",
		"tab.hoverBackground": "#cccccc",
		"tab.hoverForeground": "#000000",
		"editorGroup.dropBackground": "#8a8a8a5e",
		"editorGroup.dropIntoPromptBackground": "#8a8a8a5e",
		"sideBar.dropBackground": "#8a8a8a5e",
		"list.dropBackground": "#8a8a8a5e"
	},
	"tokenColors": [
	{
		"name": "Comments",
		"scope": [
			"comment",
			"punctuation.definition.comment"
		],
		"settings": {
		"fontStyle": "italic",
			"foreground": "#2b2b2b"
		}
	},
	{
		"name": "Keywords",
		"scope": [
			"keyword",
			"storage"
		],
		"settings": {
			"foreground": "#ff0000"
		}
	},
	{
		"name": "Variables",
		"scope": [
			"variable",
			"support.variable"
		],
		"settings": {
			"foreground": "#000000"
		}
	},
	{
		"name": "Functions",
		"scope": [
			"entity.name.function",
			"support.function"
		],
		"settings": {
			"foreground": "#ff0000"
		}
	},
	{
		"name": "Strings",
		"scope": "string",
		"settings": {
			"foreground": "#dd1f1f"
		}
	},
	{
		"name": "Numbers",
		"scope": [
			"constant.numeric",
			"constant.character"
		],
		"settings": {
			"foreground": "#000000"
		}
	},
	{
		"name": "Punctuation",
		"scope": "punctuation",
		"settings": {
			"foreground": "#000000"
		}
	}
	]
}
